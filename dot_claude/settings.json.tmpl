{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-websearch.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "svelte@svelte": true,
    "interface-design@interface-design": true,
    "codex@openai-codex": true,
    "linear-cli@linear-cli": true,
    "i-said-yes@i-said-yes": true
  },
  "extraKnownMarketplaces": {
    "svelte": {
      "source": {
        "source": "github",
        "repo": "sveltejs/ai-tools"
      }
    },
    "interface-design": {
      "source": {
        "source": "github",
        "repo": "Dammyjay93/interface-design"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "linear-cli": {
      "source": {
        "source": "github",
        "repo": "schpet/linear-cli"
      }
    },
    "i-said-yes": {
      "source": {
        "source": "github",
        "repo": "seankao31/i-said-yes"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
