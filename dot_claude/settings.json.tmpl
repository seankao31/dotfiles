{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-websearch.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "svelte@svelte": true,
    "interface-design@interface-design": true,
    "codex@openai-codex": true,
    "linear-cli@linear-cli": true,
    "sensible-ralph@sensible-ralph": true
  },
  "extraKnownMarketplaces": {
    "svelte": {
      "source": {
        "source": "github",
        "repo": "sveltejs/ai-tools"
      },
      "autoUpdate": true
    },
    "interface-design": {
      "source": {
        "source": "github",
        "repo": "Dammyjay93/interface-design"
      },
      "autoUpdate": true
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "linear-cli": {
      "source": {
        "source": "github",
        "repo": "schpet/linear-cli"
      },
      "autoUpdate": true
    },
    "i-said-yes": {
      "source": {
        "source": "github",
        "repo": "seankao31/i-said-yes"
      },
      "autoUpdate": true
    },
    "sensible-ralph": {
      "source": {
        "source": "github",
        "repo": "seankao31/sensible-ralph"
      },
      "autoUpdate": true
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
